# Supabase — get these from your Supabase project (Project Settings → API).
# Pin the project to a UK/EU region (data residency, Section 1 of the spec).
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-public-key

# Server-only. NEVER expose to the browser; used only in server contexts
# (e.g. trusted SECURITY DEFINER RPC calls / admin tasks). Do not commit a real value.
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
