# Supabase — get these from your Supabase project (Project Settings → API keys).
# Pin the project to a UK/EU region (data residency, Section 1 of the spec).
#
# Use the NEW API key format (introduced 2025), not the deprecated anon /
# service_role JWTs:
#   • Publishable key  → starts with  sb_publishable_…   (safe in the browser)
#   • Secret key       → starts with  sb_secret_…        (server-only, never shipped)

NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co

# Client + RLS-scoped server reads. Safe to expose to the browser; every access
# is still gated by Row Level Security.
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=sb_publishable_your-publishable-key

# SERVER-ONLY. NEVER expose to the browser, never put in a NEXT_PUBLIC_* var.
# Used only for genuinely privileged work — the engine write path and seeding.
SUPABASE_SECRET_KEY=sb_secret_your-secret-key

# Provider swap. "supabase" uses the live database; anything else (or unset)
# uses the in-memory demo provider, so tests and a no-network demo keep working.
NEXT_PUBLIC_DATA_PROVIDER=memory
